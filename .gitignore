# =====================================================================
# Credo CMS — .gitignore
# =====================================================================

# ---- .NET / Visual Studio ----
[Bb]in/
[Oo]bj/
[Oo]ut/
[Dd]ebug/
[Rr]elease/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
project.lock.json
project.fragment.lock.json
.vs/
*.vsidx
*.lastbuildstate
*.cache
*.binlog
*.tlog
*.svclog
*.psess
*.vsp
*.vspx

# ---- ReSharper / Rider ----
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
.idea/

# ---- NuGet ----
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
.nuget/
*.nuspec

# ---- EF Core ----
# Migrations themselves are tracked. Local design-time artifacts are not.
*.dbmdl
*.jfm

# ---- Local databases ----
*.mdf
*.ldf
*.ndf
*.sqlite
*.sqlite-journal
*.db

# ---- Test results / coverage ----
[Tt]est[Rr]esult*/
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
.coverage/
.coverage.*

# ---- Node / Vite / SPA ----
node_modules/
dist/
dist-ssr/
.vite/
.turbo/
.parcel-cache/
*.tsbuildinfo
vite.config.*.timestamp-*

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Environment / secrets ----
.env
.env.*
!.env.example
*.pem
*.pfx
*.key
secrets.json

# Local Development settings may contain real DB credentials in dev — keep out of git
# until the project owner adds their own template equivalent.
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

# ---- VS Code ----
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---- Claude Code workspace settings ----
.claude/

# ---- Azurite (Azure Storage emulator) local data ----
__azurite_db_*.json
__blobstorage__/
__queuestorage__/
__tablestorage__/

# ---- OS ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---- Misc ----
*.swp
*.bak
*.tmp
*.orig
*.rej
.history/

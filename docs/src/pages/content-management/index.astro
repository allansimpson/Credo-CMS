import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Content Management">
  <h1>Content Management</h1>

  <p>Credo CMS treats the public site and the admin shell as different surfaces of the same content. Editors and Administrators can author across all entities listed below; Members see only the published, non-members-only subset.</p>
  <ul>
    <li><a href="/docs/content-management/pages">Pages</a> — long-form content, system pages (Privacy / Terms), version history.</li>
    <li><a href="/docs/content-management/news">News</a> — time-bounded updates, optional event-date metadata.</li>
    <li><a href="/docs/content-management/blog">Blog</a> — author bylines, categories, sermon companion links, scheduled publishing.</li>
    <li><a href="/docs/content-management/sermons">Sermons</a> — YouTube embed, transcript search, structured Scripture references.</li>
    <li><a href="/docs/content-management/sermon-series">Sermon Series</a> — multi-sermon arcs.</li>
    <li><a href="/docs/content-management/events">Events</a> — recurrence, registration, calendar feeds.</li>
    <li><a href="/docs/content-management/classes">Classes</a> — class slot + offering model with audience-age-group filtering.</li>
    <li><a href="/docs/content-management/documents">Documents</a> — file uploads with category tagging.</li>
    <li><a href="/docs/content-management/leaders">Leaders</a> — staff and volunteer-leader directory entries.</li>
    <li><a href="/docs/content-management/service-times">Service Times</a> — weekly schedule shown on the public homepage.</li>
  </ul>
</BaseLayout>

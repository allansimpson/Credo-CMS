---
export interface Props {
  keys: string | string[];
}
const { keys } = Astro.props;
const arr = typeof keys === "string" ? keys.split("+").map((s) => s.trim()) : keys;
---
<span class="inline-flex items-center gap-1 not-prose">
  {arr.map((key, i) => (
    <>
      <kbd>{key}</kbd>
      {i < arr.length - 1 && <span class="text-xs text-muted">+</span>}
    </>
  ))}
</span>

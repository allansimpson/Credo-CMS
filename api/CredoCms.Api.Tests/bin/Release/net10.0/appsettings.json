{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "AzureSignalR": ""
  },

  "Storage": {
    "BlobConnectionString": "",
    "ImagesContainer": "images"
  },

  "Authentication": {
    "Cookie": {
      "Name": ".CredoCms.Auth",
      "Domain": ""
    },
    "Cors": {
      "DevAllowedOrigins": [ "http://localhost:5173" ]
    }
  },

  "Identity": {
    "DefaultAdminEmail": "admin@example.com",
    "DefaultAdminPassword": "Ch@ngeMeOnFirstLogin!"
  },

  "PublicSite": {
    "BaseUrl": "https://localhost:5001"
  },

  "Versioning": {
    "TrimCron": "0 3 * * *",
    "DefaultRetentionCount": 20
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/credocms-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },

  "ApplicationInsights": {
    "ConnectionString": ""
  },

  "AllowedHosts": "*"
}
